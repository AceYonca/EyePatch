<Window x:Class="EyePatch.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EyePatch"
        Height="650"
        Width="1000"
        MinHeight="560"
        MinWidth="850"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <SolidColorBrush x:Key="TextBrush" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#94A3B8"/>
        <SolidColorBrush x:Key="HeaderBrush" Color="#93C5FD"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#1D4ED8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#60A5FA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="RowBackground" Value="#0F172A"/>
            <Setter Property="AlternatingRowBackground" Value="#111827"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeight" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="Foreground" Value="{StaticResource HeaderBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderBrush" Value="#1E293B"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E293B"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1D4ED8"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Padding" Value="14,8"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#020617"/>
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="CaretBrush" Value="#60A5FA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Border Background="#020617"
            CornerRadius="16"
            BorderBrush="#1E293B"
            BorderThickness="1">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Background="#0F172A"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="14,0,0,0">
                    <TextBlock Text="👁"
                               FontSize="14"
                               Margin="0,0,8,0"/>

                    <TextBlock Text="EyePatch"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#E5E7EB"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">

                    <Button Content="—"
                            Style="{StaticResource TitleButtonStyle}"
                            Click="Minimize_Click"/>

                    <Button Content="□"
                            Style="{StaticResource TitleButtonStyle}"
                            Click="Maximize_Click"/>

                    <Button Content="✕"
                            Style="{StaticResource TitleButtonStyle}"
                            Background="#991B1B"
                            Foreground="White"
                            Click="Close_Click"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="170"/>
                </Grid.RowDefinitions>

                <Border Background="#0F172A"
                        BorderBrush="#1E293B"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="18"
                        Margin="0,0,0,14">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="46"
                                Height="46"
                                CornerRadius="14"
                                Background="#1D4ED8"
                                VerticalAlignment="Center"
                                Margin="0,0,14,0">
                            <TextBlock Text="👁"
                                       FontSize="22"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center">
                            <TextBlock Text="EyePatch"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#F8FAFC"/>

                            <TextBlock Text="Live process hook manager"
                                       FontSize="13"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Margin="0,3,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">

                            <CheckBox x:Name="LiveRefreshCheckBox"
                                      Content="Live Refresh"
                                      Margin="0,0,16,0"
                                      Checked="LiveRefresh_Checked"
                                      Unchecked="LiveRefresh_Unchecked"/>

                            <Button Content="Manual Refresh"
                                    Width="140"
                                    Click="Refresh_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Background="#0F172A"
                        BorderBrush="#1E293B"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="0"
                        Margin="0,0,0,14">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DockPanel Margin="16,14,16,10">
                            <TextBlock Text="Detected Processes"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#E5E7EB"
                                       DockPanel.Dock="Left"/>

                            <TextBlock Text="Right-click a row to Hook or Unhook"
                                       FontSize="12"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       DockPanel.Dock="Right"
                                       Width="659"/>
                        </DockPanel>

                        <DataGrid x:Name="ProcessGrid"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  MouseDoubleClick="ProcessGrid_MouseDoubleClick"
                                  AlternationCount="2"
                                  Margin="1,0,1,1">

                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Hook" Click="Hook_Click"/>
                                    <MenuItem Header="Unhook" Click="Unhook_Click"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="PROCESS"
                                                    Binding="{Binding ProcessName}"
                                                    Width="*"/>

                                <DataGridTextColumn Header="PID"
                                                    Binding="{Binding Id}"
                                                    Width="110"/>

                                <DataGridTextColumn Header="MEMORY"
                                                    Binding="{Binding MemoryUsage}"
                                                    Width="140"/>

                                <DataGridTextColumn Header="HOOK STATUS"
                                                    Binding="{Binding HookStatus}"
                                                    Width="140"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Background="#020617"
                        BorderBrush="#1E293B"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="14">

                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top"
                                   Margin="0,0,0,8">
                            <TextBlock Text="Console"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#93C5FD"
                                       DockPanel.Dock="Left"/>

                            <TextBlock Text="runtime activity"
                                       FontSize="12"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       DockPanel.Dock="Right"/>
                        </DockPanel>

                        <TextBox x:Name="ConsoleBox"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"/>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>